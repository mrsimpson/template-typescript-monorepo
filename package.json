{
  "name": "modern-monorepo-example",
  "version": "0.0.0-development",
  "private": true,
  "description": "Template for a typescript based monorepo, batteries included",
  "author": "Oliver Jägle <github@beimir.net>",
  "license": "MIT",
  "keywords": [
    "NPM",
    "package",
    "monorepo",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mrsimpson/template-typescript-monorepo"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean:build",
    "dev": "turbo run dev",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint:all": "turbo run --parallel lint",
    "lint:fix:all": "turbo run --parallel lint:fix",
    "format:check:all": "turbo run --parallel format",
    "format:all": "turbo run --parallel format:fix",
    "typecheck:all": "turbo run --parallel typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "knip": "knip",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "@turbo/gen": "^2.8.17",
    "@vitest/coverage-v8": "catalog:",
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "lint-staged": "^16.4.0",
    "oxlint": "catalog:",
    "prettier": "catalog:",
    "turbo": "^2.8.17",
    "typescript": "catalog:",
    "vitepress": "1.6.4",
    "vitepress-plugin-mermaid": "2.0.17",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
